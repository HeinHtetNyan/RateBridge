APP_NAME=Currency Exchange API
DEBUG=False
API_PREFIX=/api

EXCHANGE_API_URL=https://api.frankfurter.dev/v1/latest
BINANCE_P2P_URL=https://p2p.binance.com/bapi/c2c/v2/friendly/c2c/adv/search
CBM_API_URL=https://forex.cbm.gov.mm/api/latest

MYANMAR_MARKET_API_KEY=
MYANMAR_MARKET_BASE_URL=

# Airwallex MarketFX API (primary source for USD/THB and USD/EUR)
# Requires MarketFX product enabled on your account
# Get credentials at https://www.airwallex.com/app/developer/apikeys
AIRWALLEX_CLIENT_ID=
AIRWALLEX_API_KEY=

CACHE_TTL=60
HTTP_TIMEOUT=10.0
BINANCE_ROWS=10

# Comma-separated list of allowed frontend origins
ALLOWED_ORIGINS=https://your-app.vercel.app,http://localhost:3000
